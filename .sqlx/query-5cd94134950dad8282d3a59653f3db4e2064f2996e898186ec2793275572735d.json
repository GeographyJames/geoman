{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT f.id,\n                f.name,\n                f.is_primary,\n                ST_AsGeoJSON(ST_Transform(fo.geom, 4326))::jsonb as \"geometry!: Json<Geometry>\",\n                f.properties\n            FROM app.project_features f\n            JOIN app.feature_objects fo ON fo.project_feature_id = f.id\n            WHERE f.id = $1\n            ",
